  textDisplay: {fileID: 0}
  textImage: {fileID: 0}
  sentences:
  - "\u4E3B\u89D2\uFF1A\u5947\u602A\u4E86\u2026\u6211\u525B\u525B\u660E\u660E\u662F\u5728\u795E\u6BBF\u907A\u8DE1\u9032\u884C\u8003\u53E4\uFF0C\u9019\u88E1\u662F\u54EA\u88E1\u5462\uFF1F"
  - "\u4E3B\u89D2\uFF1A\u5148\u5230\u8655\u641C\u67E5\u770B\u770B\uFF0C\u627E\u627E\u6709\u4EC0\u9EBC\u3002"
  - "\u4E3B\u89D2\uFF1A\u9019\u9999\u83C7\u4E5F\u592A\u5927\u4E86\u5427\uFF0C\u6211\u6839\u672C\u904E\u4E0D\u53BB\u3002"
  - "\u4E3B\u89D2\uFF1A\u9019\u88E1\u4F3C\u4E4E\u662F\u67D0\u500B\u6751\u838A\uFF0C\u4F46\u600E\u9EBC\u90FD\u6C92\u6709\u4EBA\u7684\u8E64\u5F71\uFF1F"
  - "\u6372\u5C3E\u7334\u4EBA\uFF1A\u4F60\u9019\u500B\u5165\u4FB5\u8005\uFF01\u4F86\u9019\u88E1\u60F3\u505A\u4EC0\u9EBC\uFF01"
  - "\u4E3B\u89D2\uFF1A\u4E0D\u662F\u7684\u2026\u6211\u53EA\u662F\u8FF7\u8DEF\u7D93\u904E\u9019\u88E1\uFF01"
  - "\u6372\u5C3E\u7334\u4EBA\uFF1A\u4F60\u4E00\u5B9A\u662F\u9CE5\u6D3E\u4F86\u7684\uFF01"
